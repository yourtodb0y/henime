<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Admin - King Komik</title>
    <style>
        body { 
            background-color: #121212; 
            color: white; 
            font-family: Arial, sans-serif; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            height: 100vh; 
            margin: 0; 
        }
        .login-box { 
            width: 100%; 
            max-width: 360px; 
            background: #1e1e1e; 
            padding: 30px; 
            border-radius: 8px; 
            box-shadow: 0 4px 15px rgba(0,0,0,0.5);
            box-sizing: border-box;
        }
        h2 { text-align: center; color: #ff79c6; margin-bottom: 25px; }
        label { font-size: 14px; color: #aaa; }
        input { 
            width: 100%; 
            padding: 12px; 
            margin: 8px 0 20px 0; 
            border-radius: 4px; 
            border: none; 
            background: #2d2d2d; 
            color: white; 
            box-sizing: border-box;
        }
        button { 
            width: 100%; 
            padding: 12px; 
            background: #ff79c6; 
            color: white; 
            font-weight: bold; 
            border: none; 
            border-radius: 4px; 
            cursor: pointer; 
            font-size: 16px;
        }
        button:hover { background: #ff92df; }
        .back-link { text-align: center; display: block; margin-top: 15px; color: #aaa; text-decoration: none; font-size: 13px; }
    </style>
</head>
<body>

<div class="login-box">
    <h2>LOGIN ADMIN</h2>
    <form action="/api/login" method="POST">
        <label>Username</label>
        <input type="text" name="username" placeholder="Masukkan username admin..." required>

        <label>Password</label>
        <input type="password" name="password" placeholder="Masukkan password..." required>

        <button type="submit">MASUK</button>
    </form>
    <a href="/" class="back-link">← Kembali ke Beranda</a>
</div>

</body>
</html>

