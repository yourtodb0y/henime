<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>King Komik - Kategori Genre</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Arial', sans-serif; }
        body { background: #121212; color: #f0f0f0; padding-bottom: 80px; }
        
        .header-nav { background: #1e1e1e; padding: 15px; display: flex; align-items: center; gap: 15px; border-bottom: 1px solid #2d2d2d; }
        .header-nav a { color: #fff; text-decoration: none; font-size: 18px; }
        .header-nav h1 { font-size: 16px; font-weight: bold; text-transform: uppercase; color: #e05ec7; }

        .container { max-width: 600px; margin: 0 auto; padding: 15px; }

        /* GAMBAR 1: DAFTAR KOTAK GENRE UTAMA */
        .section-title { font-size: 14px; font-weight: 900; background: #e5b3f0; color: #000; padding: 10px; border-radius: 6px; margin-bottom: 15px; text-transform: uppercase; }
        .grid-genres { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .genre-card { background: #1e1e1e; border: 1px solid #2d2d2d; padding: 12px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; text-decoration: none; }
        .genre-card:hover { border-color: #e05ec7; }
        /* Warna Merah (Tag/Genre) */
        .gen-name { color: #f397e0; font-size: 13px; font-weight: bold; text-transform: uppercase; }
        /* Warna Hijau (Jumlah Komik) */
        .gen-count { background: #2ecc71; color: #fff; font-size: 11px; font-weight: bold; padding: 3px 8px; border-radius: 12px; }

        /* GAMBAR 2: KETIKA GENRE DIKLIK */
        /* Warna Merah Banner Atas */
        .filter-header-banner { background: #e74c3c; color: #fff; padding: 12px; border-radius: 6px; font-weight: bold; font-size: 14px; text-transform: uppercase; margin-bottom: 15px; display: flex; align-items: center; justify-content: space-between; }
        .filter-header-banner a { color: #fff; text-decoration: none; background: rgba(0,0,0,0.3); padding: 4px 10px; border-radius: 4px; font-size: 11px; }
        
        /* Warna Biru: List Hasil Pencarian Komik */
        .komik-list-box { display: flex; flex-direction: column; gap: 10px; }
        .komik-item { display: flex; gap: 12px; background: #1e1e1e; padding: 10px; border-radius: 8px; border: 1px solid #3498db; text-decoration: none; color: #fff; }
        .komik-item img { width: 65px; height: 90px; object-fit: cover; border-radius: 4px; }
        .komik-details { display: flex; flex-direction: column; justify-content: center; gap: 5px; }
        .komik-title { font-size: 14px; font-weight: bold; color: #fff; }
        .komik-meta { font-size: 11px; color: #aaa; }
        .komik-tags { display: flex; gap: 4px; flex-wrap: wrap; }
        .mini-tag { background: rgba(224, 94, 199, 0.15); color: #f397e0; font-size: 9px; padding: 1px 5px; border-radius: 3px; text-transform: uppercase; }

        /* Navigasi Bawah */
        .bottom-nav { position: fixed; bottom: 0; left: 0; width: 100%; height: 60px; background: #1e1e1e; border-top: 1px solid #2d2d2d; display: flex; justify-content: space-around; align-items: center; z-index: 1000; }
        .nav-item { text-align: center; text-decoration: none; color: #aaa; font-size: 11px; font-weight: bold; display: flex; flex-direction: column; align-items: center; }
        .nav-item.active { color: #e05ec7; }
        .nav-item i { font-size: 20px; margin-bottom: 4px; }
    </style>
</head>
<body>

    <div class="header-nav">
        <a href="/"><i class="fa-solid fa-arrow-left"></i></a>
        <h1>Daftar Kategori Genre</h1>
    </div>

    <div class="container">
        
        <% if (!genreDipilih) { %>
            
            <div class="section-title"><i class="fa-solid fa-tags"></i> Pilih Genre Komik</div>
            <div class="grid-genres">
                <% daftarGenreUnik.forEach(function(genre) { %>
                    <a href="/genres?type=<%= genre %>" class="genre-card">
                        <span class="gen-name"><%= genre %></span>
                        <span class="gen-count"><%= hitungGenre[genre] %></span>
                    </a>
                <% }); %>
            </div>

        <% } else { %>

            <div class="filter-header-banner">
                <span><i class="fa-solid fa-folder-open"></i> Genre : <%= genreDipilih %></span>
                <a href="/genres"><i class="fa-solid fa-rotate-left"></i> Kembali</a>
            </div>

            <div class="komik-list-box">
                <% if (komikTerfilter.length > 0) { %>
                    <% komikTerfilter.forEach(function(komik) { %>
                        <a href="/baca/<%= komik.id %>" class="komik-item">
                            <img src="<%= komik.cover %>" alt="Cover">
                            <div class="komik-details">
                                <h3 class="komik-title"><%= komik.judul %></h3>
                                <div class="komik-meta">Type: <%= komik.infoDetail.type %> | Status: <%= komik.infoDetail.status %></div>
                                <div class="komik-tags">
                                    <% komik.genre.forEach(function(g) { %>
                                        <span class="mini-tag"><%= g %></span>
                                    <% }); %>
                                </div>
                            </div>
                        </a>
                    <% }); %>
                <% } else { %>
                    <p style="text-align: center; color: #aaa; padding: 20px;">Belum ada komik dengan genre ini.</p>
                <% } %>
            </div>

        <% } %>

    </div>

    <div class="bottom-nav">
        <a href="/" class="nav-item"><i class="fa-solid fa-house"></i>Home</a>
        <a href="/genres" class="nav-item active"><i class="fa-solid fa-folder"></i>Genre List</a>
    </div>

</body>
</html>

